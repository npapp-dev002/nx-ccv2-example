{
  "name": "my-spartacus-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/my-spartacus-app/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/my-spartacus-app",
        "browser": "apps/my-spartacus-app/src/main.ts",
        "server": "apps/my-spartacus-app/src/main.server.ts",
        "ssr": {
          "entry": "apps/my-spartacus-app/src/main.server.ts"
        },
        "polyfills": ["zone.js"],
        "tsConfig": "apps/my-spartacus-app/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/my-spartacus-app/public"
          },
          {
            "glob": "**/*",
            "input": "./node_modules/@spartacus/smartedit/assets",
            "output": "assets/"
          }
        ],
        "styles": [
          "apps/my-spartacus-app/src/styles.scss",
          "apps/my-spartacus-app/src/styles/spartacus/user.scss",
          "apps/my-spartacus-app/src/styles/spartacus/cart.scss",
          "apps/my-spartacus-app/src/styles/spartacus/order.scss",
          "apps/my-spartacus-app/src/styles/spartacus/checkout.scss",
          "apps/my-spartacus-app/src/styles/spartacus/storefinder.scss",
          "apps/my-spartacus-app/src/styles/spartacus/asm.scss",
          "apps/my-spartacus-app/src/styles/spartacus/product.scss"
        ],
        "stylePreprocessorOptions": {
          "includePaths": ["node_modules/"],
          "sass": {
            "silenceDeprecations": ["import"]
          }
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kB",
              "maximumError": "3.5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kB",
              "maximumError": "8kB"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "my-spartacus-app:build:production"
        },
        "development": {
          "buildTarget": "my-spartacus-app:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "tsConfig": "apps/my-spartacus-app/tsconfig.spec.json",
        "stylePreprocessorOptions": {
          "includePaths": ["node_modules/"]
        },
        "styles": [
          "apps/my-spartacus-app/src/styles/spartacus/user.scss",
          "apps/my-spartacus-app/src/styles/spartacus/cart.scss",
          "apps/my-spartacus-app/src/styles/spartacus/order.scss",
          "apps/my-spartacus-app/src/styles/spartacus/checkout.scss",
          "apps/my-spartacus-app/src/styles/spartacus/storefinder.scss",
          "apps/my-spartacus-app/src/styles/spartacus/asm.scss",
          "apps/my-spartacus-app/src/styles/spartacus/product.scss"
        ],
        "assets": [
          {
            "glob": "**/*",
            "input": "./node_modules/@spartacus/smartedit/assets",
            "output": "assets/"
          }
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
